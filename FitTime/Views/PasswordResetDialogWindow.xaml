<Window x:Class="FitTime.Views.PasswordResetDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="СБРОС ПАРОЛЯ" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A1A1A"
        TextElement.Foreground="White"
        TextElement.FontFamily="Roboto">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="СБРОС ПАРОЛЯ" FontSize="16" FontWeight="Bold"
                   Foreground="#F4B448" Margin="0,0,0,12"/>

        <!-- User info -->
        <TextBlock Grid.Row="1" Text="{Binding UserInfo}" Foreground="#888" FontSize="13" Margin="0,0,0,20"/>

        <!-- New Password -->
        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="НОВЫЙ ПАРОЛЬ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
            <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
        </StackPanel>

        <!-- Confirm Password -->
        <StackPanel Grid.Row="3" Margin="0,0,0,14">
            <TextBlock Text="ПОДТВЕРЖДЕНИЕ ПАРОЛЯ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
            <TextBox Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
        </StackPanel>

        <!-- Error message -->
        <TextBlock Grid.Row="4" Text="{Binding ErrorMessage}" Foreground="#C0392B" FontSize="12"
                   Margin="0,0,0,16" TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=.}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="ОТМЕНА" Click="Cancel_Click"
                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="#666" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="СБРОСИТЬ" Command="{Binding ResetCommand}"
                    Background="#C0392B" Foreground="White" FontWeight="Bold" FontSize="12"
                    Height="36" Padding="24,0"/>
        </StackPanel>
    </Grid>
</Window>
