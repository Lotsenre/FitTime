<UserControl x:Class="FitTime.Views.ClassDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#1A1A1A">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Class header -->
        <Grid Grid.Row="0" Background="#0A0A0A">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="56" Height="56" CornerRadius="4"
                    Background="{Binding AccentColor}" Margin="24,12">
                <materialDesign:PackIcon Kind="Dumbbell" Width="24" Height="24"
                                         Foreground="White"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding ClassName}" Foreground="White" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="{Binding ClassMeta}" Foreground="#555" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Grid.Column="2" Background="{Binding StatusBgColor}" CornerRadius="2"
                    Padding="12,4" Margin="24,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontSize="11" FontWeight="Bold"/>
            </Border>
        </Grid>

        <!-- Tabs -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,8,24,0">
            <RadioButton Content="ОСНОВНОЕ" GroupName="ClassTab" IsChecked="True"
                         Style="{StaticResource MaterialDesignTabRadioButton}"
                         Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,0,24,0"
                         Command="{Binding SetTabCommand}" CommandParameter="Основное"/>
            <RadioButton Content="УЧАСТНИКИ" GroupName="ClassTab"
                         Style="{StaticResource MaterialDesignTabRadioButton}"
                         Foreground="#555" FontSize="12"
                         Command="{Binding SetTabCommand}" CommandParameter="Участники"/>
        </StackPanel>

        <!-- Tab content -->
        <ScrollViewer Grid.Row="2" Margin="24,16,24,0" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Основное tab -->
                <Grid Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Основное}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 1: Class Type / Trainer -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                        <TextBlock Text="ТИП ЗАНЯТИЯ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding ClassTypes}" SelectedItem="{Binding SelectedClassType}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,16">
                        <TextBlock Text="ТРЕНЕР" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding Trainers}" SelectedItem="{Binding SelectedTrainer}"
                                  DisplayMemberPath="ShortName"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" FontSize="14"/>
                    </StackPanel>

                    <!-- Row 2: Date / Start Time / End Time -->
                    <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ДАТА" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding ClassDate}"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="НАЧАЛО" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding StartTime, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="ОКОНЧАНИЕ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding EndTime, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 3: Max Participants / Room -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,16">
                        <TextBlock Text="МАКС. УЧАСТНИКОВ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding MaxParticipants, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,16">
                        <TextBlock Text="ЗАЛ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Room, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
                    </StackPanel>
                </Grid>

                <!-- Участники tab -->
                <Grid Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Участники}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Add participant row -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableClients}"
                                  SelectedItem="{Binding SelectedNewClient}"
                                  DisplayMemberPath="FullName"
                                  materialDesign:HintAssist.Hint="Выберите клиента"
                                  materialDesign:HintAssist.IsFloating="False"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" FontSize="13"
                                  Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="ЗАПИСАТЬ"
                                Command="{Binding AddParticipantCommand}"
                                Background="#F4B448" Foreground="Black" FontWeight="Bold" FontSize="12"
                                Height="36" Padding="20,0"/>
                    </Grid>

                    <!-- Participants count -->
                    <TextBlock Grid.Row="1" Foreground="#888" FontSize="13" Margin="0,0,0,12">
                        <Run Text="Записано: "/>
                        <Run Text="{Binding ParticipantsCountText}" FontWeight="Bold" Foreground="White"/>
                    </TextBlock>

                    <!-- Headers -->
                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="КЛИЕНТ" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="1" Text="АБОНЕМЕНТ" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="2" Text="СТАТУС" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="3" Text="ЗАПИСАН" FontSize="11" Foreground="#666"/>
                    </Grid>

                    <ListBox Grid.Row="3" ItemsSource="{Binding Participants}"
                             SelectedItem="{Binding SelectedParticipant}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="3,0,0,1" BorderBrush="{Binding BorderColor}"
                                        Padding="12,10" Margin="0,1,0,0" Background="#1E1E1E">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ClientName}" Foreground="White" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding MembershipInfo}" Foreground="#888" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        <Border Grid.Column="2" Background="{Binding StatusBgColor}" CornerRadius="2"
                                                Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="{Binding EnrolledAt}" Foreground="#555" FontSize="12" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="ОТМЕТИТЬ" Command="{Binding MarkPresentCommand}"
                                Background="#2D5C42" Foreground="#7ED9A6" FontWeight="Bold" FontSize="12"
                                Height="32" Padding="16,0" Margin="0,0,8,0"/>
                        <Button Content="СНЯТЬ ОТМЕТКУ" Command="{Binding MarkAbsentCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#888" FontSize="12" Margin="0,0,8,0"/>
                        <Button Content="ОТПИСАТЬ" Command="{Binding RemoveParticipantCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#C0392B" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,8,24,16">
            <Button Content="ОТМЕНА" Command="{Binding CancelCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="#666" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="СОХРАНИТЬ" Command="{Binding SaveCommand}"
                    Background="#F4B448" Foreground="Black" FontWeight="Bold" FontSize="12"
                    Height="36" Padding="24,0"
                    Visibility="{Binding CanEdit, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>
