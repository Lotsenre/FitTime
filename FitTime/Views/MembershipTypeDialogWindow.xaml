<Window x:Class="FitTime.Views.MembershipTypeDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding DialogTitle}" Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A1A1A"
        TextElement.Foreground="White"
        TextElement.FontFamily="Roboto">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="{Binding DialogTitle}" FontSize="16" FontWeight="Bold"
                   Foreground="#F4B448" Margin="0,0,0,20"/>

        <!-- Name -->
        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="НАЗВАНИЕ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
        </StackPanel>

        <!-- Duration -->
        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="ДЛИТЕЛЬНОСТЬ (ДНЕЙ)" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
            <TextBox Text="{Binding DurationDays, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
        </StackPanel>

        <!-- Visit Count -->
        <StackPanel Grid.Row="3" Margin="0,0,0,14"
                    Visibility="{Binding IsUnlimited, Converter={StaticResource InverseBoolToVisConverter}}">
            <TextBlock Text="КОЛИЧЕСТВО ПОСЕЩЕНИЙ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
            <TextBox Text="{Binding VisitCount, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
        </StackPanel>

        <!-- IsUnlimited -->
        <CheckBox Grid.Row="4" Content="Безлимитный" IsChecked="{Binding IsUnlimited}"
                  Foreground="White" FontSize="13" Margin="0,0,0,14"/>

        <!-- Price -->
        <StackPanel Grid.Row="5" Margin="0,0,0,24">
            <TextBlock Text="ЦЕНА (₽)" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
            <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="ОТМЕНА" Click="Cancel_Click"
                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="#666" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="СОХРАНИТЬ" Command="{Binding SaveCommand}"
                    Background="#F4B448" Foreground="Black" FontWeight="Bold" FontSize="12"
                    Height="36" Padding="24,0"/>
        </StackPanel>
    </Grid>
</Window>
