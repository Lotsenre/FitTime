<UserControl x:Class="FitTime.Views.AttendanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#1A1A1A">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filter bar -->
        <Grid Grid.Row="0" Margin="24,12,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Date From -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="ДАТА С" FontSize="10" Foreground="#666" Margin="0,0,0,4"/>
                <DatePicker SelectedDate="{Binding DateFrom}"
                            materialDesign:HintAssist.Hint="Начало"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Width="130" FontSize="13"/>
            </StackPanel>

            <!-- Date To -->
            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                <TextBlock Text="ДО" FontSize="10" Foreground="#666" Margin="0,0,0,4"/>
                <DatePicker SelectedDate="{Binding DateTo}"
                            materialDesign:HintAssist.Hint="Конец"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Width="130" FontSize="13"/>
            </StackPanel>

            <!-- Client filter -->
            <StackPanel Grid.Column="2" Margin="0,0,24,0">
                <TextBlock Text="КЛИЕНТ" FontSize="10" Foreground="#666" Margin="0,0,0,4"/>
                <TextBox Text="{Binding ClientFilter, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Фамилия..."
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="200" FontSize="13"/>
            </StackPanel>

            <!-- Status filters -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,4">
                <RadioButton Content="ВСЕ" GroupName="AttFilter" IsChecked="True"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Foreground="#F4B448" FontSize="12" Margin="0,0,12,0"
                             Command="{Binding SetStatusFilterCommand}" CommandParameter="Все"/>
                <RadioButton Content="ОТМЕЧЕНО" GroupName="AttFilter"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Foreground="White" FontSize="12"
                             Command="{Binding SetStatusFilterCommand}" CommandParameter="Отмечено"/>
            </StackPanel>
        </Grid>

        <!-- Column headers -->
        <Grid Grid.Row="1" Margin="24,12,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="КЛИЕНТ" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="1" Text="ЗАНЯТИЕ" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="2" Text="ТРЕНЕР" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="3" Text="ДАТА / ВРЕМЯ" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="4" Text="СТАТУС" FontSize="11" Foreground="#666"/>
        </Grid>

        <!-- Attendance list -->
        <ListBox Grid.Row="2" Margin="24,8,24,0"
                 ItemsSource="{Binding Attendances}"
                 SelectedItem="{Binding SelectedAttendance}"
                 Background="Transparent" BorderThickness="0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,1,0,0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" Background="#1E1E1E" Padding="12" BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#F4B448"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#252525"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ClientName}" Foreground="{Binding ClientNameColor}" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding ClassName}" Foreground="{Binding DetailColor}" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding TrainerName}" Foreground="{Binding DetailColor}" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{Binding DateTimeText}" Foreground="{Binding DetailColor}" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="24,8,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#666" FontSize="13">
                <Run Text="Показано "/>
                <Run Text="{Binding Attendances.Count, Mode=OneWay}"/>
                <Run Text=" из "/>
                <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                <Run Text=" записей"/>
            </TextBlock>

            <Button Grid.Column="1" Content="ОТМЕНИТЬ ОТМЕТКУ"
                    Command="{Binding CancelAttendanceCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="#666" FontSize="12" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="ОТМЕТИТЬ"
                    Command="{Binding MarkAttendanceCommand}"
                    Background="#F4B448" Foreground="Black"
                    FontWeight="Bold" FontSize="12"
                    Height="36" Padding="24,0"/>
        </Grid>
    </Grid>
</UserControl>
