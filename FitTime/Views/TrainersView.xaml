<UserControl x:Class="FitTime.Views.TrainersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="24,16,24,0">
            <TextBlock Text="ТРЕНЕРЫ" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <Button Content="+ ДОБАВИТЬ" HorizontalAlignment="Right"
                    Command="{Binding AddTrainerCommand}"
                    Background="#F4B448" Foreground="Black" FontWeight="Bold" FontSize="13"
                    Height="38" Padding="20,0"/>
        </Grid>

        <!-- Column headers -->
        <Grid Grid.Row="1" Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="ФИО" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="1" Text="ТЕЛЕФОН" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="2" Text="EMAIL" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="3" Text="СПЕЦИАЛИЗАЦИЯ" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="4" Text="ЗАНЯТИЙ / МЕС." FontSize="11" Foreground="#666"/>
        </Grid>

        <!-- List -->
        <ListBox Grid.Row="2" Margin="24,8,24,0"
                 ItemsSource="{Binding Trainers}"
                 SelectedItem="{Binding SelectedTrainer}"
                 Background="Transparent" BorderThickness="0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,1,0,0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" Background="#1E1E1E" Padding="12" BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#F4B448"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#252525"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding FullName}" Foreground="White" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Grid.Column="1" Text="{Binding Phone}" Foreground="#888" FontSize="13"/>
                        <TextBlock Grid.Column="2" Text="{Binding Email}" Foreground="#888" FontSize="13"/>
                        <TextBlock Grid.Column="3" Text="{Binding Specialization}" Foreground="#888" FontSize="13"/>
                        <TextBlock Grid.Column="4" Text="{Binding ClassesPerMonth}" Foreground="#F4B448" FontSize="14" FontWeight="Bold"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,8,24,16">
            <Button Content="УДАЛИТЬ" Command="{Binding DeleteTrainerCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="#C04040" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="РЕДАКТИРОВАТЬ" Command="{Binding EditTrainerCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="РАСПИСАНИЕ" Command="{Binding ViewScheduleCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="ЗАГРУЖЕННОСТЬ" Command="{Binding ViewWorkloadCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" FontSize="12"/>
        </StackPanel>
    </Grid>
</UserControl>
