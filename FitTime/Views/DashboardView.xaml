<UserControl x:Class="FitTime.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#1A1A1A">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- KPI Cards -->
        <UniformGrid Grid.Row="0" Rows="1" Columns="4" Margin="0,0,0,24">
            <Border Background="#252525" CornerRadius="4" Padding="20" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="{Binding ActiveClientsCount}" FontSize="42" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="АКТИВНЫХ КЛИЕНТОВ" FontSize="11" Foreground="#808080" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#252525" CornerRadius="4" Padding="20" Margin="6,0">
                <StackPanel>
                    <TextBlock Text="{Binding TodayClassesCount}" FontSize="42" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="ЗАНЯТИЙ СЕГОДНЯ" FontSize="11" Foreground="#808080" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#252525" CornerRadius="4" Padding="20" Margin="6,0">
                <StackPanel>
                    <TextBlock Text="{Binding MonthSalesCount}" FontSize="42" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="ПРОДАЖ ЗА МЕСЯЦ" FontSize="11" Foreground="#808080" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#252525" CornerRadius="4" Padding="20" Margin="12,0,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding ExpiringMembershipsCount}" FontSize="42" FontWeight="Bold" Foreground="#F4B448"/>
                    <TextBlock Text="ИСТЕКАЕТ АБОНЕМЕНТОВ" FontSize="11" Foreground="#808080" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Charts area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Weekly attendance chart + Recent memberships -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Weekly attendance bar chart -->
                <Border Grid.Row="0" Background="#0D0D0D" CornerRadius="4" Padding="20" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="180"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="ПОСЕЩАЕМОСТЬ ЗА НЕДЕЛЮ" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,12"/>

                        <!-- Bars -->
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding WeeklyBars}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <!-- Count label on top of bar -->
                                        <TextBlock Text="{Binding Count}" Foreground="#888" FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <!-- Bar -->
                                        <Border Background="{Binding BarColor}" Height="{Binding BarHeight}"
                                                Width="40" CornerRadius="3,3,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Day labels -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding WeeklyBars}" Margin="0,6,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding DayLabel}" Foreground="#666" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding DateLabel}" Foreground="#444" FontSize="9" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Recent memberships -->
                <Border Grid.Row="1" Background="#0D0D0D" CornerRadius="4" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="ПОСЛЕДНИЕ ПРОДАЖИ" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,12"/>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding RecentMemberships}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#1A1A1A" BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding ClientName}" Foreground="White" FontSize="13" FontWeight="Medium"/>
                                                <TextBlock Foreground="#555" FontSize="11" Margin="0,2,0,0">
                                                    <Run Text="{Binding TypeName}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding Date}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Price}" Foreground="#F4B448" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right: Today's schedule -->
            <Border Grid.Column="2" Background="#0D0D0D" CornerRadius="4" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="РАСПИСАНИЕ НА СЕГОДНЯ" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,12"/>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding TodayClasses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1A1A1A" BorderThickness="0,0,0,1" Padding="0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Time -->
                                        <TextBlock Grid.Column="0" Text="{Binding TimeText}" Foreground="#F4B448" FontSize="12" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="0,0,16,0" Width="110"/>

                                        <!-- Class info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ClassName}" Foreground="White" FontSize="13" FontWeight="Medium"/>
                                            <TextBlock Foreground="#555" FontSize="11" Margin="0,2,0,0">
                                                <Run Text="{Binding TrainerName}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding ParticipantsText}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Status -->
                                        <TextBlock Grid.Column="2" Text="{Binding StatusText}" Foreground="{Binding StatusColor}"
                                                   FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state -->
                    <TextBlock Grid.Row="1" Text="Нет занятий на сегодня" Foreground="#444" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding TodayClasses.Count, Converter={StaticResource InverseBoolToVisConverter}}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
