<Window x:Class="FitTime.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:FitTime.ViewModels"
        xmlns:views="clr-namespace:FitTime.Views"
        Title="FitTime — Панель управления"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#1A1A1A"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontFamily="Roboto"
        Closed="Window_Closed">

    <Window.Resources>
        <!-- DataTemplate bindings for navigation -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClientsViewModel}">
            <views:ClientsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MembershipTypesViewModel}">
            <views:MembershipTypesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ScheduleViewModel}">
            <views:ScheduleView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TrainersViewModel}">
            <views:TrainersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AttendanceViewModel}">
            <views:AttendanceView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <views:UsersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClientDialogViewModel}">
            <views:ClientDialogView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClassDialogViewModel}">
            <views:ClassDialogView/>
        </DataTemplate>

        <!-- Nav tab button style -->
        <Style x:Key="NavTabStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="16,12" Background="Transparent">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="12" FontWeight="Medium"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Background="#0D0D0D" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Hamburger menu button -->
                <Button Grid.Column="0" Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding ToggleMenuCommand}"
                        Foreground="White" Margin="0,0,8,0">
                    <materialDesign:PackIcon Kind="Menu" Width="24" Height="24"/>
                </Button>

                <!-- Logo -->
                <TextBlock Grid.Column="1" Text="FITTIME"
                           FontSize="18" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <!-- Current page title -->
                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentView.Title}"
                           FontSize="14" Foreground="#808080"
                           VerticalAlignment="Center"/>

                <!-- User info + logout -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding LogoutCommand}"
                            Foreground="#666" ToolTip="Выход" Margin="0,0,8,0">
                        <materialDesign:PackIcon Kind="Logout" Width="20" Height="20"/>
                    </Button>
                    <Border Width="36" Height="36" CornerRadius="18"
                            Background="#F4B448" Margin="0,0,10,0">
                        <TextBlock Text="{Binding UserInitials}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="Black"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding UserName}" FontSize="13" Foreground="White"/>
                        <TextBlock Text="{Binding UserRole}" FontSize="11" Foreground="#F4B448"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Horizontal nav tabs (collapsible) -->
        <Border Grid.Row="1" Background="#0D0D0D" BorderBrush="#222222" BorderThickness="0,0,0,1"
                Visibility="{Binding IsMenuOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" Margin="56,0,16,0">

                <!-- ПАНЕЛЬ -->
                <Border BorderThickness="0,0,0,2"
                        BorderBrush="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='0,underline'}">
                    <Button Content="ПАНЕЛЬ" Command="{Binding NavigateToDashboardCommand}"
                            Style="{StaticResource NavTabStyle}"
                            Foreground="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='0,fg'}"/>
                </Border>

                <!-- КЛИЕНТЫ -->
                <Border BorderThickness="0,0,0,2"
                        BorderBrush="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='1,underline'}"
                        Visibility="{Binding IsManagerOrAdminVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Content="КЛИЕНТЫ" Command="{Binding NavigateToClientsCommand}"
                            Style="{StaticResource NavTabStyle}"
                            Foreground="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='1,fg'}"/>
                </Border>

                <!-- АБОНЕМЕНТЫ -->
                <Border BorderThickness="0,0,0,2"
                        BorderBrush="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='2,underline'}"
                        Visibility="{Binding IsManagerOrAdminVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Content="АБОНЕМЕНТЫ" Command="{Binding NavigateToMembershipsCommand}"
                            Style="{StaticResource NavTabStyle}"
                            Foreground="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='2,fg'}"/>
                </Border>

                <!-- РАСПИСАНИЕ -->
                <Border BorderThickness="0,0,0,2"
                        BorderBrush="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='3,underline'}">
                    <Button Content="РАСПИСАНИЕ" Command="{Binding NavigateToScheduleCommand}"
                            Style="{StaticResource NavTabStyle}"
                            Foreground="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='3,fg'}"/>
                </Border>

                <!-- ТРЕНЕРЫ -->
                <Border BorderThickness="0,0,0,2"
                        BorderBrush="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='4,underline'}"
                        Visibility="{Binding IsManagerOrAdminVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Content="ТРЕНЕРЫ" Command="{Binding NavigateToTrainersCommand}"
                            Style="{StaticResource NavTabStyle}"
                            Foreground="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='4,fg'}"/>
                </Border>

                <!-- ПОСЕЩЕНИЯ -->
                <Border BorderThickness="0,0,0,2"
                        BorderBrush="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='5,underline'}">
                    <Button Content="ПОСЕЩЕНИЯ" Command="{Binding NavigateToAttendanceCommand}"
                            Style="{StaticResource NavTabStyle}"
                            Foreground="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='5,fg'}"/>
                </Border>

                <!-- ОТЧЁТЫ -->
                <Border BorderThickness="0,0,0,2"
                        BorderBrush="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='6,underline'}"
                        Visibility="{Binding IsManagerOrAdminVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Content="ОТЧЁТЫ" Command="{Binding NavigateToReportsCommand}"
                            Style="{StaticResource NavTabStyle}"
                            Foreground="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='6,fg'}"/>
                </Border>

                <!-- ПОЛЬЗОВАТЕЛИ -->
                <Border BorderThickness="0,0,0,2"
                        BorderBrush="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='7,underline'}"
                        Visibility="{Binding IsAdminVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Content="ПОЛЬЗОВАТЕЛИ" Command="{Binding NavigateToUsersCommand}"
                            Style="{StaticResource NavTabStyle}"
                            Foreground="{Binding ActiveNavIndex, Converter={StaticResource ActiveNavConverter}, ConverterParameter='7,fg'}"/>
                </Border>

            </StackPanel>
        </Border>

        <!-- Main content -->
        <ContentControl Grid.Row="2" Content="{Binding CurrentView}" Margin="0"/>
    </Grid>
</Window>
