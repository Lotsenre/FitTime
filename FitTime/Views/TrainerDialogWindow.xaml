<Window x:Class="FitTime.Views.TrainerDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding DialogTitle}" Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A1A1A"
        TextElement.Foreground="White"
        TextElement.FontFamily="Roboto">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="{Binding DialogTitle}" FontSize="16" FontWeight="Bold"
                   Foreground="#F4B448" Margin="0,0,0,20"/>

        <!-- Last Name / First Name row -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="ФАМИЛИЯ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="ИМЯ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
            </StackPanel>
        </Grid>

        <!-- Patronymic -->
        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="ОТЧЕСТВО" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
            <TextBox Text="{Binding Patronymic, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
        </StackPanel>

        <!-- Phone / Email row -->
        <Grid Grid.Row="3" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="ТЕЛЕФОН" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="EMAIL" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
            </StackPanel>
        </Grid>

        <!-- Specialization -->
        <StackPanel Grid.Row="4" Margin="0,0,0,14">
            <TextBlock Text="СПЕЦИАЛИЗАЦИЯ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
            <TextBox Text="{Binding Specialization, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
        </StackPanel>

        <!-- Account link (hidden for managers) -->
        <StackPanel Grid.Row="5" Margin="0,0,0,14"
                    Visibility="{Binding IsAccountVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="АККАУНТ ТРЕНЕРА" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
            <ComboBox ItemsSource="{Binding TrainerAccounts}" SelectedItem="{Binding SelectedAccount}"
                      DisplayMemberPath="ShortName"
                      materialDesign:HintAssist.Hint="Отсутствует"
                      materialDesign:HintAssist.IsFloating="False"
                      materialDesign:TextFieldAssist.HasClearButton="True"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}" FontSize="14"/>
        </StackPanel>

        <!-- Separator -->
        <Separator Grid.Row="6" Background="#333" Margin="0,4,0,16"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="ОТМЕНА" Click="Cancel_Click"
                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="#666" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="СОХРАНИТЬ" Command="{Binding SaveCommand}"
                    Background="#F4B448" Foreground="Black" FontWeight="Bold" FontSize="12"
                    Height="36" Padding="24,0"/>
        </StackPanel>
    </Grid>
</Window>
