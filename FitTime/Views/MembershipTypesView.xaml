<UserControl x:Class="FitTime.Views.MembershipTypesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="24,16,24,0">
            <TextBlock Text="ТИПЫ АБОНЕМЕНТОВ" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <Button Content="+ ДОБАВИТЬ" HorizontalAlignment="Right"
                    Command="{Binding AddTypeCommand}"
                    Background="#F4B448" Foreground="Black" FontWeight="Bold" FontSize="13"
                    Height="38" Padding="20,0"
                    Visibility="{Binding CanEdit, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>

        <!-- Column headers -->
        <Grid Grid.Row="1" Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="НАЗВАНИЕ" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="1" Text="ДНИ" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="2" Text="КОЛ-ВО ПОСЕЩЕНИЙ" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="3" Text="БЕЗЛИМИТ" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="4" Text="ЦЕНА" FontSize="11" Foreground="#666"/>
            <TextBlock Grid.Column="5" Text="" FontSize="11" Foreground="#666"/>
        </Grid>

        <!-- List -->
        <ListBox Grid.Row="2" Margin="24,8,24,0"
                 ItemsSource="{Binding MembershipTypes}"
                 SelectedItem="{Binding SelectedType}"
                 Background="Transparent" BorderThickness="0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,1,0,0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" Background="#1E1E1E" Padding="12" BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#F4B448"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="White" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Grid.Column="1" Text="{Binding DurationDays}" Foreground="#CCC" FontSize="14"/>
                        <TextBlock Grid.Column="2" Text="{Binding VisitCount}" Foreground="#CCC" FontSize="14"/>
                        <TextBlock Grid.Column="3" Foreground="#CCC" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="—"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUnlimited}" Value="True">
                                            <Setter Property="Text" Value="ДА"/>
                                            <Setter Property="Foreground" Value="#F4B448"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Grid.Column="4" Foreground="#F4B448" FontSize="14" FontWeight="Bold">
                            <Run Text="{Binding Price, StringFormat='{}{0:N0}'}"/><Run Text=" ₽"/>
                        </TextBlock>
                        <TextBlock Grid.Column="5" Foreground="#666" FontSize="12" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value=""/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsArchived}" Value="True">
                                            <Setter Property="Text" Value="АРХИВ"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,8,24,16"
                    Visibility="{Binding CanEdit, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Button Content="РЕДАКТИРОВАТЬ" Command="{Binding EditTypeCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="АРХИВИРОВАТЬ" Command="{Binding ArchiveTypeCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" FontSize="12"/>
        </StackPanel>
    </Grid>
</UserControl>
