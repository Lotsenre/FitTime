<UserControl x:Class="FitTime.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#1A1A1A">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="24,16,24,0">
            <TextBlock Text="ОТЧЁТЫ" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <Button Content="&#x2193; ЭКСПОРТ CSV" HorizontalAlignment="Right"
                    Command="{Binding ExportCsvCommand}"
                    Background="#F4B448" Foreground="Black" FontWeight="Bold" FontSize="12"
                    Height="38" Padding="20,0"/>
        </Grid>

        <!-- Tabs -->
        <Grid Grid.Row="1" Margin="24,12,24,0">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="ПОСЕЩАЕМОСТЬ" GroupName="ReportTab" IsChecked="True"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,24,0"
                             Command="{Binding SetTabCommand}" CommandParameter="Посещаемость"/>
                <RadioButton Content="ПРОДАЖИ" GroupName="ReportTab"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Foreground="#666" FontSize="13" Margin="0,0,24,0"
                             Command="{Binding SetTabCommand}" CommandParameter="Продажи"/>
                <RadioButton Content="ИСТЕКАЮТ" GroupName="ReportTab"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Foreground="#666" FontSize="13" Margin="0,0,24,0"
                             Command="{Binding SetTabCommand}" CommandParameter="Истекают"/>
                <RadioButton Content="ЗАГРУЖЕННОСТЬ" GroupName="ReportTab"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Foreground="#666" FontSize="13"
                             Command="{Binding SetTabCommand}" CommandParameter="Загруженность"/>
            </StackPanel>
        </Grid>

        <!-- Period filter -->
        <Grid Grid.Row="2" Margin="24,12,24,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ПЕРИОД:" Foreground="#555" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Width="140" FontSize="13" Margin="0,0,8,0"/>
                <TextBlock Text="—" Foreground="#666" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Width="140" FontSize="13" Margin="0,0,12,0"/>
                <Button Content="ПРИМЕНИТЬ" Command="{Binding ApplyFilterCommand}"
                        Background="#F4B448" Foreground="Black"
                        FontWeight="Bold" FontSize="12"
                        Height="32" Padding="16,0"/>
            </StackPanel>
        </Grid>

        <!-- Content area -->
        <ScrollViewer Grid.Row="3" Margin="24,16,24,16" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Attendance tab content -->
                <Grid Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Посещаемость}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Chart + Stats row -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <!-- Bar chart -->
                        <Border Grid.Column="0" Background="#000000" CornerRadius="4" Padding="20" Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="200"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="ПОСЕЩАЕМОСТЬ ПО ДНЯМ НЕДЕЛИ" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,16"/>
                                <UniformGrid Grid.Row="1" Columns="7">
                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding MondayCount}" Foreground="#888" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                        <Border Background="#F4B448" Height="{Binding MondayCount, Converter={StaticResource CountToBarHeightConverter}}" Width="50" CornerRadius="3,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding TuesdayCount}" Foreground="#888" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                        <Border Background="#F4B448" Height="{Binding TuesdayCount, Converter={StaticResource CountToBarHeightConverter}}" Width="50" CornerRadius="3,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding WednesdayCount}" Foreground="#888" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                        <Border Background="#F4B448" Height="{Binding WednesdayCount, Converter={StaticResource CountToBarHeightConverter}}" Width="50" CornerRadius="3,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding ThursdayCount}" Foreground="#888" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                        <Border Background="#F4B448" Height="{Binding ThursdayCount, Converter={StaticResource CountToBarHeightConverter}}" Width="50" CornerRadius="3,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding FridayCount}" Foreground="#888" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                        <Border Background="#F4B448" Height="{Binding FridayCount, Converter={StaticResource CountToBarHeightConverter}}" Width="50" CornerRadius="3,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SaturdayCount}" Foreground="#888" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                        <Border Background="#F4B448" Opacity="0.6" Height="{Binding SaturdayCount, Converter={StaticResource CountToBarHeightConverter}}" Width="50" CornerRadius="3,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SundayCount}" Foreground="#888" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                        <Border Background="#F4B448" Opacity="0.35" Height="{Binding SundayCount, Converter={StaticResource CountToBarHeightConverter}}" Width="50" CornerRadius="3,3,0,0"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Grid.Row="2" Columns="7" Margin="0,8,0,0">
                                    <TextBlock Text="ПН" Foreground="#888" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Text="ВТ" Foreground="#888" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Text="СР" Foreground="#888" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Text="ЧТ" Foreground="#888" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Text="ПТ" Foreground="#888" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Text="СБ" Foreground="#666" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Text="ВС" Foreground="#555" FontSize="11" HorizontalAlignment="Center"/>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <!-- Stats panel -->
                        <Border Grid.Column="1" Background="#000000" CornerRadius="4" Padding="20">
                            <StackPanel>
                                <TextBlock Text="ИТОГО ЗА ПЕРИОД" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,16"/>
                                <Rectangle Fill="#1A1A1A" Height="1" Margin="0,0,0,16"/>

                                <TextBlock Text="ПОСЕЩЕНИЙ" Foreground="#555" FontSize="11"/>
                                <TextBlock Text="{Binding TotalAttendance}" Foreground="#F4B448" FontSize="32" FontWeight="Bold" Margin="0,0,0,16"/>
                                <Rectangle Fill="#1A1A1A" Height="1" Margin="0,0,0,16"/>

                                <TextBlock Text="УНИКАЛЬНЫХ КЛИЕНТОВ" Foreground="#555" FontSize="11"/>
                                <TextBlock Text="{Binding UniqueClients}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,0,0,16"/>
                                <Rectangle Fill="#1A1A1A" Height="1" Margin="0,0,0,16"/>

                                <TextBlock Text="СРЕДНЕЕ В ДЕНЬ" Foreground="#555" FontSize="11"/>
                                <TextBlock Text="{Binding AvgPerDay}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,0,0,16"/>
                                <Rectangle Fill="#1A1A1A" Height="1" Margin="0,0,0,16"/>

                                <TextBlock Text="ОТМЕНЕНО / НЕ ЯВИЛОСЬ" Foreground="#555" FontSize="11"/>
                                <TextBlock Text="{Binding CancelledCount}" Foreground="#888" FontSize="32" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Top classes section -->
                    <TextBlock Grid.Row="1" Text="ТОП ЗАНЯТИЙ ЗА ПЕРИОД" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,24,0,8"/>

                    <!-- Top classes table -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Headers -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ЗАНЯТИЕ" FontSize="11" Foreground="#666"/>
                            <TextBlock Grid.Column="1" Text="ТРЕНЕР" FontSize="11" Foreground="#666"/>
                            <TextBlock Grid.Column="2" Text="ПОСЕЩЕНИЙ" FontSize="11" Foreground="#666"/>
                            <TextBlock Grid.Column="3" Text="ЗАГРУЖЕННОСТЬ" FontSize="11" Foreground="#666"/>
                            <TextBlock Grid.Column="4" Text="% ОТМЕН" FontSize="11" Foreground="#666"/>
                        </Grid>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding TopClasses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#141414" BorderThickness="0,0,0,1" Padding="0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding ClassName}" Foreground="White" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TrainerName}" Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding AttendanceCount}" Foreground="#F4B448" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Background="{Binding LoadBarColor}" Height="8" Width="{Binding LoadBarWidth}" CornerRadius="4" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding LoadPercent, StringFormat='{}{0:F0}%'}" Foreground="White" FontSize="13"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="4" Text="{Binding CancelPercent}" Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>

                <!-- Sales tab content -->
                <Grid Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Продажи}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Sales KPIs -->
                    <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,24">
                        <Border Background="#000000" CornerRadius="4" Padding="20" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="ПРОДАНО АБОНЕМЕНТОВ" Foreground="#555" FontSize="11"/>
                                <TextBlock Text="{Binding SoldCount}" Foreground="#F4B448" FontSize="32" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#000000" CornerRadius="4" Padding="20" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="ВЫРУЧКА" Foreground="#555" FontSize="11"/>
                                <TextBlock Foreground="White" FontSize="32" FontWeight="Bold">
                                    <Run Text="{Binding TotalRevenue, StringFormat='{}{0:N0}'}"/><Run Text=" ₽"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Background="#000000" CornerRadius="4" Padding="20" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="СРЕДНИЙ ЧЕК" Foreground="#555" FontSize="11"/>
                                <TextBlock Foreground="White" FontSize="32" FontWeight="Bold">
                                    <Run Text="{Binding AvgPrice, StringFormat='{}{0:N0}'}"/><Run Text=" ₽"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Sales by type table -->
                    <TextBlock Grid.Row="1" Text="ПРОДАЖИ ПО ТИПАМ АБОНЕМЕНТОВ" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding SalesByType}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#141414" BorderThickness="0,0,0,1" Padding="0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TypeName}" Foreground="White" FontSize="14" FontWeight="Medium"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Count}" Foreground="#F4B448" FontSize="14" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Foreground="White" FontSize="14">
                                            <Run Text="{Binding Revenue, StringFormat='{}{0:N0}'}"/><Run Text=" ₽"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- Expiring tab content -->
                <Grid Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Истекают}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#000000" CornerRadius="4" Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="ИСТЕКАЕТ В БЛИЖАЙШИЕ 7 ДНЕЙ" Foreground="#555" FontSize="11"/>
                            <TextBlock Text="{Binding ExpiringCount}" Foreground="#F4B448" FontSize="32" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="КЛИЕНТ" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="1" Text="АБОНЕМЕНТ" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="2" Text="ДАТА ОКОНЧАНИЯ" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="3" Text="ДНЕЙ" FontSize="11" Foreground="#666"/>
                    </Grid>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding ExpiringMemberships}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#141414" BorderThickness="0,0,0,1" Padding="0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ClientName}" Foreground="White" FontSize="14" FontWeight="Medium"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TypeName}" Foreground="#888" FontSize="13"/>
                                        <TextBlock Grid.Column="2" Text="{Binding EndDate}" Foreground="#888" FontSize="13"/>
                                        <TextBlock Grid.Column="3" Text="{Binding DaysLeft}" Foreground="{Binding DaysLeftColor}" FontSize="14" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- Workload tab content (reuses attendance data) -->
                <Grid Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Загруженность}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ЗАГРУЖЕННОСТЬ ЗАНЯТИЙ ЗА ПЕРИОД" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding TopClasses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#141414" BorderThickness="0,0,0,1" Padding="0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ClassName}" Foreground="White" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TrainerName}" Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding AttendanceCount}" Foreground="#F4B448" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Background="{Binding LoadBarColor}" Height="8" Width="{Binding LoadBarWidth}" CornerRadius="4" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding LoadPercent, StringFormat='{}{0:F0}%'}" Foreground="White" FontSize="13"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="4" Text="{Binding CancelPercent}" Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
