<UserControl x:Class="FitTime.Views.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#1A1A1A">
    <UserControl.Resources>
        <!-- Reusable class block template for calendar day columns -->
        <DataTemplate x:Key="CalendarBlockTemplate">
            <Border Background="{Binding BorderColor}" CornerRadius="4"
                    Height="{Binding BlockHeight}" Margin="2,0"
                    Padding="8,6" Cursor="Hand"
                    Canvas.Top="{Binding TopOffset}">
                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick"
                                  Command="{Binding DataContext.EditClassByIdCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding Id}"/>
                </Border.InputBindings>
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="{Binding ClassName}" Foreground="White" FontSize="12" FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding TrainerName}" Foreground="#AAAAAA" FontSize="10" Margin="0,2,0,0"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding ParticipantsText}" Foreground="{Binding ParticipantsColor}" FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ItemsControl style for each day column -->
        <Style x:Key="DayColumnItemsControl" TargetType="ItemsControl">
            <Setter Property="ItemTemplate" Value="{StaticResource CalendarBlockTemplate}"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <Canvas/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Top" Value="{Binding TopOffset}"/>
                        <Setter Property="Canvas.Left" Value="0"/>
                        <Setter Property="Width" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Navigation bar -->
        <Grid Grid.Row="0" Background="#000000">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Week navigation -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="24,10,0,10" VerticalAlignment="Center">
                <Button Content="&#x25C0;" Command="{Binding PreviousWeekCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#555" FontSize="12" MinWidth="30" Padding="4"/>
                <TextBlock Text="{Binding WeekRangeText}" Foreground="White" FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="8,0"/>
                <Button Content="&#x25B6;" Command="{Binding NextWeekCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#555" FontSize="12" MinWidth="30" Padding="4"/>
            </StackPanel>

            <!-- View toggle -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                <RadioButton Content="НЕДЕЛЯ" GroupName="ScheduleView" IsChecked="{Binding IsWeekView}"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Foreground="#F4B448" FontSize="12" Margin="0,0,8,0"
                             Command="{Binding SwitchToWeekViewCommand}"/>
                <RadioButton Content="СПИСОК" GroupName="ScheduleView"
                             Style="{StaticResource MaterialDesignTabRadioButton}"
                             Foreground="White" FontSize="12"
                             Command="{Binding SwitchToListViewCommand}"/>
            </StackPanel>

            <!-- Add button -->
            <Button Grid.Column="4" Content="+ ЗАНЯТИЕ"
                    Command="{Binding AddClassCommand}"
                    Background="#F4B448" Foreground="Black"
                    FontWeight="Bold" FontSize="12"
                    Height="32" Padding="16,0" Margin="0,0,24,0"
                    Visibility="{Binding CanEdit, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>

        <!-- ============================================ -->
        <!-- WEEK VIEW: Calendar grid                     -->
        <!-- ============================================ -->
        <Grid Grid.Row="1" Visibility="{Binding IsWeekView, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Day headers -->
            <Grid Grid.Row="0" Background="#0D0D0D">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Empty top-left corner -->
                <Border Grid.Column="0" BorderBrush="#1A1A1A" BorderThickness="0,0,1,1"/>
                <TextBlock Grid.Column="1" Text="{Binding Day1Header}" FontSize="12" HorizontalAlignment="Center" Padding="0,10"
                           Foreground="{Binding TodayDayIndex, Converter={StaticResource TodayHighlightConverter}, ConverterParameter=0}"/>
                <TextBlock Grid.Column="2" Text="{Binding Day2Header}" FontSize="12" HorizontalAlignment="Center" Padding="0,10"
                           Foreground="{Binding TodayDayIndex, Converter={StaticResource TodayHighlightConverter}, ConverterParameter=1}"/>
                <TextBlock Grid.Column="3" Text="{Binding Day3Header}" FontSize="12" HorizontalAlignment="Center" Padding="0,10"
                           Foreground="{Binding TodayDayIndex, Converter={StaticResource TodayHighlightConverter}, ConverterParameter=2}"/>
                <TextBlock Grid.Column="4" Text="{Binding Day4Header}" FontSize="12" HorizontalAlignment="Center" Padding="0,10"
                           Foreground="{Binding TodayDayIndex, Converter={StaticResource TodayHighlightConverter}, ConverterParameter=3}"/>
                <TextBlock Grid.Column="5" Text="{Binding Day5Header}" FontSize="12" HorizontalAlignment="Center" Padding="0,10"
                           Foreground="{Binding TodayDayIndex, Converter={StaticResource TodayHighlightConverter}, ConverterParameter=4}"/>
                <TextBlock Grid.Column="6" Text="{Binding Day6Header}" FontSize="12" HorizontalAlignment="Center" Padding="0,10"
                           Foreground="{Binding TodayDayIndex, Converter={StaticResource TodayHighlightConverter}, ConverterParameter=5}"/>
                <TextBlock Grid.Column="7" Text="{Binding Day7Header}" FontSize="12" HorizontalAlignment="Center" Padding="0,10"
                           Foreground="{Binding TodayDayIndex, Converter={StaticResource TodayHighlightConverter}, ConverterParameter=6}"/>
            </Grid>

            <!-- Scrollable time grid -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Height="{Binding GridHeight}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Time labels + horizontal grid lines -->
                    <Canvas Grid.Column="0" Grid.ColumnSpan="8">
                        <!-- 07:00 -->
                        <TextBlock Canvas.Top="0" Canvas.Left="8" Text="07:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="0" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 08:00 -->
                        <TextBlock Canvas.Top="70" Canvas.Left="8" Text="08:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="70" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 09:00 -->
                        <TextBlock Canvas.Top="140" Canvas.Left="8" Text="09:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="140" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 10:00 -->
                        <TextBlock Canvas.Top="210" Canvas.Left="8" Text="10:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="210" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 11:00 -->
                        <TextBlock Canvas.Top="280" Canvas.Left="8" Text="11:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="280" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 12:00 -->
                        <TextBlock Canvas.Top="350" Canvas.Left="8" Text="12:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="350" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 13:00 -->
                        <TextBlock Canvas.Top="420" Canvas.Left="8" Text="13:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="420" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 14:00 -->
                        <TextBlock Canvas.Top="490" Canvas.Left="8" Text="14:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="490" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 15:00 -->
                        <TextBlock Canvas.Top="560" Canvas.Left="8" Text="15:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="560" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 16:00 -->
                        <TextBlock Canvas.Top="630" Canvas.Left="8" Text="16:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="630" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 17:00 -->
                        <TextBlock Canvas.Top="700" Canvas.Left="8" Text="17:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="700" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 18:00 -->
                        <TextBlock Canvas.Top="770" Canvas.Left="8" Text="18:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="770" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 19:00 -->
                        <TextBlock Canvas.Top="840" Canvas.Left="8" Text="19:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="840" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 20:00 -->
                        <TextBlock Canvas.Top="910" Canvas.Left="8" Text="20:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="910" Stroke="#1E1E1E" StrokeThickness="1"/>
                        <!-- 21:00 -->
                        <TextBlock Canvas.Top="980" Canvas.Left="8" Text="21:00" Foreground="#444" FontSize="11"/>
                        <Line X1="52" X2="5000" Canvas.Top="980" Stroke="#1E1E1E" StrokeThickness="1"/>
                    </Canvas>

                    <!-- Day columns with class blocks -->
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Day0Classes}" Style="{StaticResource DayColumnItemsControl}"/>
                    <ItemsControl Grid.Column="2" ItemsSource="{Binding Day1Classes}" Style="{StaticResource DayColumnItemsControl}"/>
                    <ItemsControl Grid.Column="3" ItemsSource="{Binding Day2Classes}" Style="{StaticResource DayColumnItemsControl}"/>
                    <ItemsControl Grid.Column="4" ItemsSource="{Binding Day3Classes}" Style="{StaticResource DayColumnItemsControl}"/>
                    <ItemsControl Grid.Column="5" ItemsSource="{Binding Day4Classes}" Style="{StaticResource DayColumnItemsControl}"/>
                    <ItemsControl Grid.Column="6" ItemsSource="{Binding Day5Classes}" Style="{StaticResource DayColumnItemsControl}"/>
                    <ItemsControl Grid.Column="7" ItemsSource="{Binding Day6Classes}" Style="{StaticResource DayColumnItemsControl}"/>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ============================================ -->
        <!-- LIST VIEW                                    -->
        <!-- ============================================ -->
        <Grid Grid.Row="1" Visibility="{Binding IsWeekView, Converter={StaticResource InverseBoolToVisConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Filters -->
            <Grid Grid.Row="0" Background="#000000">
                <StackPanel Orientation="Horizontal" Margin="24,8,24,8">
                    <TextBlock Text="ТРЕНЕР:" Foreground="#555" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding TrainerFilters}"
                              SelectedItem="{Binding SelectedTrainerFilter}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Width="200" FontSize="13" Margin="0,0,24,0"/>
                    <TextBlock Text="ТИП:" Foreground="#555" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding TypeFilters}"
                              SelectedItem="{Binding SelectedTypeFilter}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Width="200" FontSize="13"/>
                </StackPanel>
            </Grid>

            <!-- Column headers -->
            <Grid Grid.Row="1" Margin="24,8,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ЗАНЯТИЕ" FontSize="11" Foreground="#666"/>
                <TextBlock Grid.Column="1" Text="ТРЕНЕР" FontSize="11" Foreground="#666"/>
                <TextBlock Grid.Column="2" Text="ДАТА / ВРЕМЯ" FontSize="11" Foreground="#666"/>
                <TextBlock Grid.Column="3" Text="УЧАСТНИКИ" FontSize="11" Foreground="#666"/>
                <TextBlock Grid.Column="4" Text="СТАТУС" FontSize="11" Foreground="#666"/>
            </Grid>

            <!-- Classes list -->
            <ListBox Grid.Row="2" Margin="24,8,24,0"
                     ItemsSource="{Binding Classes}"
                     SelectedItem="{Binding SelectedClass}"
                     Background="Transparent" BorderThickness="0"
                     MouseDoubleClick="ClassesList_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,1,0,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="#1E1E1E" Padding="12" BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#F4B448"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#252525"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding ClassName}" Foreground="White" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="{Binding Room}" Foreground="#555" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding TrainerName}" Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding DateTimeText}" Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding ParticipantsText}" Foreground="{Binding ParticipantsColor}" FontSize="13" VerticalAlignment="Center"/>
                            <Border Grid.Column="4" Background="{Binding StatusBgColor}" CornerRadius="2"
                                    Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Footer -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,8,24,16">
                <Button Content="РЕДАКТИРОВАТЬ" Command="{Binding EditClassCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" FontSize="12" Margin="0,0,8,0"
                        Visibility="{Binding CanEdit, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
