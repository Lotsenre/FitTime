<Window x:Class="FitTime.Views.MembershipDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ОФОРМИТЬ АБОНЕМЕНТ" Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A1A1A"
        TextElement.Foreground="White"
        TextElement.FontFamily="Roboto">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="ОФОРМИТЬ АБОНЕМЕНТ" FontSize="16" FontWeight="Bold"
                   Foreground="#F4B448" Margin="0,0,0,20"/>

        <!-- Client -->
        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="КЛИЕНТ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
            <ComboBox ItemsSource="{Binding Clients}" SelectedItem="{Binding SelectedClient}"
                      DisplayMemberPath="FullName"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}" FontSize="14"/>
        </StackPanel>

        <!-- Membership Type -->
        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="ТИП АБОНЕМЕНТА" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
            <ComboBox ItemsSource="{Binding MembershipTypes}" SelectedItem="{Binding SelectedType}"
                      DisplayMemberPath="Name"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}" FontSize="14"/>
        </StackPanel>

        <!-- Start Date -->
        <StackPanel Grid.Row="3" Margin="0,0,0,14">
            <TextBlock Text="ДАТА НАЧАЛА" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
            <DatePicker SelectedDate="{Binding StartDate}"
                        Style="{StaticResource MaterialDesignOutlinedDatePicker}" FontSize="14"/>
        </StackPanel>

        <!-- End Date (computed) -->
        <StackPanel Grid.Row="4" Margin="0,0,0,14"
                    Visibility="{Binding EndDateText, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=.}">
            <TextBlock Text="ДАТА ОКОНЧАНИЯ" Foreground="#666" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding EndDateText}" Foreground="White" FontSize="14"/>
        </StackPanel>

        <!-- Price (computed) -->
        <StackPanel Grid.Row="5" Margin="0,0,0,14"
                    Visibility="{Binding PriceText, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=.}">
            <TextBlock Text="СТОИМОСТЬ" Foreground="#666" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding PriceText}" Foreground="#F4B448" FontSize="16" FontWeight="Bold"/>
        </StackPanel>

        <!-- Info -->
        <TextBlock Grid.Row="6" Text="{Binding InfoText}" Foreground="#888" FontSize="12"
                   TextWrapping="Wrap" Margin="0,0,0,20"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="ОТМЕНА" Click="Cancel_Click"
                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="#666" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="ОФОРМИТЬ" Command="{Binding SaveCommand}"
                    Background="#F4B448" Foreground="Black" FontWeight="Bold" FontSize="12"
                    Height="36" Padding="24,0"/>
        </StackPanel>
    </Grid>
</Window>
