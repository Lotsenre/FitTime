<UserControl x:Class="FitTime.Views.ClientDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#1A1A1A">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Client header -->
        <Grid Grid.Row="0" Background="#0A0A0A" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="56" Height="56" CornerRadius="4"
                    Background="#2D4060" Margin="24,12">
                <TextBlock Text="{Binding ClientInitials}" FontSize="20" FontWeight="Bold"
                           Foreground="#7AAAD9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding ClientFullName}" Foreground="White" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="{Binding ClientSubtitle}" Foreground="#555" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Grid.Column="2" Background="{Binding StatusBgColor}" CornerRadius="2"
                    Padding="12,4" Margin="24,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontSize="11" FontWeight="Bold"/>
            </Border>
        </Grid>

        <!-- Tabs -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,8,24,0">
            <RadioButton Content="ЛИЧНЫЕ ДАННЫЕ" GroupName="ClientTab" IsChecked="True"
                         Style="{StaticResource MaterialDesignTabRadioButton}"
                         Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,0,24,0"
                         Command="{Binding SetTabCommand}" CommandParameter="Личные данные"/>
            <RadioButton Content="АБОНЕМЕНТЫ" GroupName="ClientTab"
                         Style="{StaticResource MaterialDesignTabRadioButton}"
                         Foreground="#555" FontSize="12" Margin="0,0,24,0"
                         Command="{Binding SetTabCommand}" CommandParameter="Абонементы"/>
            <RadioButton Content="ПОСЕЩЕНИЯ" GroupName="ClientTab"
                         Style="{StaticResource MaterialDesignTabRadioButton}"
                         Foreground="#555" FontSize="12"
                         Command="{Binding SetTabCommand}" CommandParameter="Посещения"/>
        </StackPanel>

        <!-- Tab content -->
        <ScrollViewer Grid.Row="2" Margin="24,16,24,0" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Personal data tab -->
                <Grid Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Личные данные}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 1: First name / Last name -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                        <TextBlock Text="ИМЯ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,16">
                        <TextBlock Text="ФАМИЛИЯ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
                    </StackPanel>

                    <!-- Row 2: Patronymic / Birth date -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,16">
                        <TextBlock Text="ОТЧЕСТВО" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Patronymic, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,16">
                        <TextBlock Text="ДАТА РОЖДЕНИЯ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                        <DatePicker SelectedDate="{Binding BirthDate}"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}" FontSize="14"/>
                    </StackPanel>

                    <!-- Row 3: Phone / Email -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,16">
                        <TextBlock Text="ТЕЛЕФОН" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,16">
                        <TextBlock Text="EMAIL" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="14"/>
                    </StackPanel>

                    <!-- Row 4: Notes -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,16">
                        <TextBlock Text="ЗАМЕТКИ" Foreground="#666" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="13" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="80" MaxHeight="160" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Grid>

                <!-- Memberships tab -->
                <Grid Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Абонементы}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Add membership button -->
                    <Button Grid.Row="0" Content="+ ОФОРМИТЬ АБОНЕМЕНТ" Command="{Binding AddMembershipCommand}"
                            HorizontalAlignment="Left" Margin="0,0,0,16"
                            Background="#F4B448" Foreground="Black" FontWeight="Bold" FontSize="12"
                            Height="36" Padding="20,0"
                            Visibility="{Binding CanEdit, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- Headers -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ТИП" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="1" Text="НАЧАЛО" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="2" Text="ОКОНЧАНИЕ" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="3" Text="ПОСЕЩЕНИЙ" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="4" Text="СТАТУС" FontSize="11" Foreground="#666"/>
                    </Grid>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Memberships}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="3,0,0,1" Padding="12,10"
                                        BorderBrush="{Binding BorderColor}" Margin="0,1,0,0" Background="#1E1E1E">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TypeName}" Foreground="White" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding StartDate}" Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding EndDate}" Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding VisitsText}" Foreground="{Binding VisitsColor}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Border Grid.Column="4" Background="{Binding StatusBgColor}" CornerRadius="2"
                                                Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- Attendance tab -->
                <Grid Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Посещения}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ЗАНЯТИЕ" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="1" Text="ТРЕНЕР" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="2" Text="ДАТА / ВРЕМЯ" FontSize="11" Foreground="#666"/>
                        <TextBlock Grid.Column="3" Text="СТАТУС" FontSize="11" Foreground="#666"/>
                    </Grid>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Attendances}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="3,0,0,1" BorderBrush="{Binding BorderColor}"
                                        Padding="12,10" Margin="0,1,0,0" Background="#1E1E1E">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ClassName}" Foreground="White" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TrainerName}" Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DateTimeText}" Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="3" Background="{Binding StatusBgColor}" CornerRadius="2"
                                                Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,8,24,16">
            <Button Content="ОТМЕНА" Command="{Binding CancelCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="#666" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="СОХРАНИТЬ" Command="{Binding SaveCommand}"
                    Background="#F4B448" Foreground="Black" FontWeight="Bold" FontSize="12"
                    Height="36" Padding="24,0"
                    Visibility="{Binding CanEdit, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>
